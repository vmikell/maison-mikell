rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function membershipDocPath(userId) {
      return /databases/$(database)/documents/users/$(userId)/meta/membership;
    }

    function householdPath(householdId) {
      return /databases/$(database)/documents/households/$(householdId);
    }

    function householdDoc(householdId) {
      return get(householdPath(householdId));
    }

    function inviteCodeDoc(inviteCode) {
      return get(/databases/$(database)/documents/inviteCodes/$(inviteCode));
    }

    function userMembershipDoc(userId) {
      return get(membershipDocPath(userId));
    }

    function householdMembers(householdId) {
      return householdDoc(householdId).data.members;
    }

    function memberEmailAt(householdId, index) {
      return householdMembers(householdId).size() > index
        ? householdMembers(householdId)[index].email
        : null;
    }

    function memberRoleAt(householdId, index) {
      return householdMembers(householdId).size() > index
        ? householdMembers(householdId)[index].role
        : null;
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && request.auth.uid != null
        && userMembershipDoc(request.auth.uid).data.householdId == householdId;
    }

    function isOwner(householdId) {
      return signedIn()
        && request.auth.uid != null
        && userMembershipDoc(request.auth.uid).data.householdId == householdId
        && userMembershipDoc(request.auth.uid).data.role == 'owner';
    }

    function membershipPayloadLooksValid(userId) {
      return request.resource.data.id == userId
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.joinedAt is string
        && request.resource.data.householdId is string
        && (request.resource.data.role == 'owner' || request.resource.data.role == 'member');
    }

    function membershipMatchesHouseholdAfter(userId) {
      return getAfter(householdPath(request.resource.data.householdId)).data.members.hasAny([
        {
          id: userId,
          email: request.resource.data.email,
          name: request.resource.data.name,
          role: request.resource.data.role,
          joinedAt: request.resource.data.joinedAt,
          householdId: request.resource.data.householdId,
        }
      ]);
    }

    function selfMembershipCreateIsValid(userId) {
      return request.auth.uid == userId
        && membershipPayloadLooksValid(userId)
        && request.resource.data.email == request.auth.token.email
        && (
          (request.resource.data.role == 'owner' && membershipMatchesHouseholdAfter(userId))
          || (
            request.resource.data.role == 'member'
            && request.resource.data.inviteCode is string
            && inviteCodeDoc(request.resource.data.inviteCode).data.householdId == request.resource.data.householdId
          )
        );
    }

    function selfMembershipUpdateIsValid(userId) {
      return request.auth.uid == userId
        && membershipPayloadLooksValid(userId)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.householdId == resource.data.householdId
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email
        && request.resource.data.joinedAt == resource.data.joinedAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['name', 'inviteCode', 'role'])
        && (
          request.resource.data.role == resource.data.role
          || membershipMatchesHouseholdAfter(userId)
        );
    }

    function ownerManagedMembershipWrite(userId) {
      return signedIn()
        && request.auth.uid != userId
        && membershipPayloadLooksValid(userId)
        && isOwner(request.resource.data.householdId)
        && membershipMatchesHouseholdAfter(userId);
    }

    function householdCreateIsValid(householdId) {
      return signedIn()
        && request.resource.data.id == householdId
        && request.resource.data.inviteCode is string
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0].id == request.auth.uid
        && request.resource.data.members[0].email == request.auth.token.email
        && request.resource.data.members[0].role == 'owner'
        && getAfter(membershipDocPath(request.auth.uid)).data.householdId == householdId
        && getAfter(membershipDocPath(request.auth.uid)).data.role == 'owner';
    }

    function isSelfSyncingHouseholdMembership(householdId) {
      return signedIn()
        && request.auth.uid != null
        && isHouseholdMember(householdId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'updatedAt'])
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.hasAny([
          {
            id: request.auth.uid,
            email: userMembershipDoc(request.auth.uid).data.email,
            name: userMembershipDoc(request.auth.uid).data.name,
            role: userMembershipDoc(request.auth.uid).data.role,
            joinedAt: userMembershipDoc(request.auth.uid).data.joinedAt,
            householdId: householdId,
          }
        ]);
    }

    match /households/{householdId} {
      allow read: if isHouseholdMember(householdId);
      allow create: if householdCreateIsValid(householdId);
      allow update: if isOwner(householdId)
        || isSelfSyncingHouseholdMembership(householdId)
        || (isHouseholdMember(householdId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastReminderRunAt', 'lastReminderChannel', 'updatedAt']));
      allow delete: if isOwner(householdId);

      match /maintenanceTasks/{taskId} {
        allow read: if isHouseholdMember(householdId);
        allow create, delete: if isOwner(householdId);
        allow update: if isOwner(householdId)
          || (isHouseholdMember(householdId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['claimedBy', 'claimedAt', 'lastDone', 'lastCompletedAt', 'lastCompletedBy', 'updatedAt']));
      }

      match /shoppingLists/{listId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update, delete: if isHouseholdMember(householdId);

        match /items/{itemId} {
          allow read: if isHouseholdMember(householdId);
          allow create, update, delete: if isHouseholdMember(householdId);
        }
      }

      match /reminders/{reminderId} {
        allow read: if isHouseholdMember(householdId);
        allow create, delete: if isOwner(householdId);
        allow update: if isOwner(householdId)
          || (isHouseholdMember(householdId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['sent', 'sentAt', 'sentChannel', 'updatedAt']));
      }

      match /activity/{entryId} {
        allow read: if isHouseholdMember(householdId);
        allow write: if isOwner(householdId);
      }

      match /completions/{entryId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if isHouseholdMember(householdId);
        allow update, delete: if isOwner(householdId);
      }
    }

    match /inviteCodes/{inviteCode} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.householdId is string
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId}/meta/{docId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if docId == 'membership'
        && (
          selfMembershipCreateIsValid(userId)
          || ownerManagedMembershipWrite(userId)
        );
      allow update: if docId == 'membership'
        && (
          selfMembershipUpdateIsValid(userId)
          || ownerManagedMembershipWrite(userId)
        );
      allow delete: if signedIn()
        && request.auth.uid == userId
        && docId == 'membership';
    }
  }
}
