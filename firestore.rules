rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function householdDoc(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId));
    }

    function userMembershipDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId)/meta/membership);
    }

    function householdMembers(householdId) {
      return householdDoc(householdId).data.members;
    }

    function memberEmailAt(householdId, index) {
      return householdMembers(householdId).size() > index
        ? householdMembers(householdId)[index].email
        : null;
    }

    function memberRoleAt(householdId, index) {
      return householdMembers(householdId).size() > index
        ? householdMembers(householdId)[index].role
        : null;
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && request.auth.uid != null
        && userMembershipDoc(request.auth.uid).data.householdId == householdId;
    }

    function isOwner(householdId) {
      return signedIn()
        && request.auth.uid != null
        && userMembershipDoc(request.auth.uid).data.householdId == householdId
        && userMembershipDoc(request.auth.uid).data.role == 'owner';
    }

    function isSelfJoiningExistingHousehold(householdId) {
      return signedIn()
        && !isHouseholdMember(householdId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'updatedAt'])
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.hasAny([
          {
            id: request.auth.uid,
            email: request.auth.token.email,
            name: request.auth.token.name != null ? request.auth.token.name : request.auth.token.email,
            role: 'member',
            joinedAt: request.resource.data.members[request.resource.data.members.size() - 1].joinedAt,
          }
        ]);
    }

    match /households/{householdId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isOwner(householdId)
        || isSelfJoiningExistingHousehold(householdId)
        || (isHouseholdMember(householdId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastReminderRunAt', 'lastReminderChannel', 'updatedAt']));
      allow delete: if isOwner(householdId);

      match /maintenanceTasks/{taskId} {
        allow read: if true;
        allow create, delete: if isOwner(householdId);
        allow update: if isOwner(householdId)
          || (isHouseholdMember(householdId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['claimedBy', 'claimedAt', 'lastDone', 'lastCompletedAt', 'lastCompletedBy', 'updatedAt']));
      }

      match /shoppingLists/{listId} {
        allow read: if true;
        allow create, update, delete: if isHouseholdMember(householdId);

        match /items/{itemId} {
          allow read: if true;
          allow create, update, delete: if isHouseholdMember(householdId);
        }
      }

      match /reminders/{reminderId} {
        allow read: if true;
        allow create, delete: if isOwner(householdId);
        allow update: if isOwner(householdId)
          || (isHouseholdMember(householdId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['sent', 'sentAt', 'sentChannel', 'updatedAt']));
      }

      match /activity/{entryId} {
        allow read: if true;
        allow write: if isOwner(householdId);
      }

      match /completions/{entryId} {
        allow read: if true;
        allow create: if isHouseholdMember(householdId);
        allow update, delete: if isOwner(householdId);
      }
    }

    match /users/{userId}/meta/{docId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && docId == 'membership';
      allow delete: if false;
    }
  }
}
